# NerdKey local Keygen CE configuration.
# Copy to `.env`, fill every empty value, and never commit `.env`.

# Keygen Docker image. Pin the minor LTS stream; do not use `latest`.
KEYGEN_IMAGE=keygen/api:v1.6

# Local TLS host. Must be a domain name, not an IP address.
KEYGEN_HOST=nerdkey.localhost
CADDY_HOSTS=nerdkey.localhost
CADDY_ACME_EMAIL=

# PostgreSQL
POSTGRES_USER=keygen
POSTGRES_PASSWORD=
POSTGRES_DB=keygen

# Redis
REDIS_URL=redis://redis:6379

# Rails and Active Record encryption secrets.
# Generate with:
#   openssl rand -hex 64
#   openssl rand -base64 32
SECRET_KEY_BASE=
ENCRYPTION_DETERMINISTIC_KEY=
ENCRYPTION_PRIMARY_KEY=
ENCRYPTION_KEY_DERIVATION_SALT=

# Keygen CE singleplayer setup.
KEYGEN_EDITION=CE
KEYGEN_MODE=singleplayer
KEYGEN_ACCOUNT_ID=
KEYGEN_ADMIN_EMAIL=
KEYGEN_ADMIN_PASSWORD=

# NerdKey admin CLI. Generate with:
#   python3 scripts/nerdkey.py token issue --save
KEYGEN_ADMIN_TOKEN=
NERDKEY_BASE_URL=https://nerdkey.localhost
NERDKEY_PRODUCTS_FILE=products.yaml
NERDKEY_TLS_VERIFY=false

# Local runtime defaults.
PORT=3000
BIND=0.0.0.0
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=1
HTTP_HEALTH_CHECK_STATUS_CODE=200
RACK_ATTACK_MAX_RPS=-1
RACK_ATTACK_MAX_RPM=-1

# Production (keys.nerdsmiths.de) — see docs/production-rollout.md.
# Carry over the SAME secrets that encrypted the migrated DB, and change only:
#   KEYGEN_HOST=keys.nerdsmiths.de
#   NERDKEY_BASE_URL=https://keys.nerdsmiths.de
#   NERDKEY_TLS_VERIFY=true        # real Let's Encrypt cert, terminate TLS at host NGINX
#   RACK_ATTACK_MAX_RPS=20         # enable per-IP rate limiting (no -1 in production)
#   RACK_ATTACK_MAX_RPM=600
# Caddy is local-dev only; do not run it in production.
