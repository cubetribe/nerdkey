# NGINX reverse proxy for NerdKey (Keygen CE) at keys.nerdsmiths.de.
#
# This is the FINAL state (HTTP -> HTTPS redirect + TLS termination), to be
# installed on the host as /etc/nginx/sites-available/keys.nerdsmiths.de.conf
# and symlinked into sites-enabled/.
#
# Deploy order matters: the 443 block below references a Let's Encrypt
# certificate that does not exist yet on a first rollout. Bring the vhost up in
# two phases (see docs/production-rollout.md):
#   1. Install an HTTP-only block exposing /.well-known/acme-challenge/, then
#      run: certbot certonly --webroot -w /var/www/html -d keys.nerdsmiths.de
#   2. Swap in this full config and reload after `nginx -t` passes.
#
# NerdKey web is bound to 127.0.0.1:3055 by docker-compose.prod.yml.

server {
    listen 80;
    listen [::]:80;
    server_name keys.nerdsmiths.de;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name keys.nerdsmiths.de;

    ssl_certificate /etc/letsencrypt/live/keys.nerdsmiths.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/keys.nerdsmiths.de/privkey.pem;

    # HSTS for this host only (no includeSubDomains: sibling *.nerdsmiths.de
    # hosts must not be forced onto HTTPS by this vhost).
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options "nosniff" always;

    # Keygen API payloads are small; keep uploads bounded.
    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3055;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
